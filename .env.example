# Local SFTP server (see docker-compose.yml). Copy to .env to run.
SFTP_HOST=127.0.0.1
SFTP_PORT=2222
SFTP_USER=clinic
SFTP_PASSWORD=clinicpass
SFTP_REMOTE_DIR=/upload

# Public HAPI FHIR R4 sandbox. SYNTHETIC DATA ONLY — never post real PHI here.
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# Namespace (system) for the patient MRN identifier. Milestone 4 keys its
# idempotent conditional create on this.
FHIR_MRN_SYSTEM=urn:clinic:intake:mrn
